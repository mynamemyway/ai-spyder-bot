# Telegram Bot Token from @BotFather
BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# OpenRouter API Key from https://openrouter.ai/keys
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# URL for the self-hosted embedding service API
EMBEDDING_SERVICE_URL="http://your_server_ip:8000/embed"

# The specific chat model to use from OpenRouter (e.g., "mistralai/mistral-small")
OPENROUTER_CHAT_MODEL="openai/gpt-oss-20b:free"

# The first fallback model to use if the primary model fails
OPENROUTER_FALLBACK_MODEL="arcee-ai/trinity-large-preview:free"

# The second fallback model to use if the first fallback fails
OPENROUTER_FALLBACK_MODEL_2="meta-llama/llama-3-8b-instruct:free"

# (Optional) Controls the creativity of the response (0.0 - 1.0)
OPENROUTER_TEMPERATURE=0.7

# (Optional) Limits the length of the generated response in tokens
OPENROUTER_MAX_TOKENS=1024

# (Optional) The number of recent messages to keep in the conversation memory window
MEMORY_WINDOW_SIZE=10

# Determines if the bot's response should be sanitized for Markdown
SANITIZE_RESPONSE=True

# (Optional) URL for the manager's Telegram contact
MANAGER_TELEGRAM_URL="https://t.me/username"

# Controls if the bot should reply only when mentioned in group chats.
# If True, the bot replies only to messages containing @bot_username in groups.
# In private chats, the bot always replies regardless of this setting.
# Default: False
REPLY_ONLY_TO_MENTIONS=False

# (Optional) System prompt for the RAG chain. Defines the AI assistant's persona.
SYSTEM_PROMPT="Ты — полезный AI-ассистент."

# (Optional) Path to the welcome photo for the /start command
WELCOME_PHOTO_PATH="assets/welcome_photo.png"

# (Optional) Path to the help photo for the /help command
HELP_PHOTO_PATH="assets/help_photo.png"
